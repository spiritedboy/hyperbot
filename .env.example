# Hyperliquid 主网: https://api.hyperliquid.xyz
# Hyperliquid 测试网: https://api.hyperliquid-testnet.xyz
HL_API_URL=https://api.hyperliquid.xyz

# 被监控地址（leader）
LEADER_ADDRESS=0x_your_leader_address

# 跟单账号私钥和地址（follower）
# 这里是 API 钱包私钥（用于签名下单）
FOLLOWER_PRIVATE_KEY=0x_your_private_key

# 这里必须是 Hyper 主地址（资金和仓位所在账户地址），不要填 API 钱包地址
FOLLOWER_ADDRESS=0x_your_follower_address

# 飞书机器人 webhook
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxx

# 固定跟单本金（U），默认 20
FIXED_MARGIN_USD=20

# websocket 断线重连间隔（秒）
WS_RECONNECT_SECONDS=3

# 市价单保护滑点（0.03 = 3%）
MARKET_SLIPPAGE=0.03

# 事件去抖（秒）：同币种事件太密时忽略
EVENT_DEBOUNCE_SECONDS=0.5

# 相同事件去重窗口（秒）
DUPLICATE_TTL_SECONDS=2

# 风控：最多同时持有多少个币种仓位
MAX_OPEN_COINS=6

# 风控：账户总本金上限（U）
MAX_TOTAL_PRINCIPAL_USD=200

# 小于该面额的订单忽略（U）
MIN_NOTIONAL_USD=5

# 是否允许做空（true/false）
ALLOW_SHORT=true

# 飞书心跳间隔（秒），<=0 关闭
HEARTBEAT_SECONDS=300

# 是否跳过真实下单（true/false）
DRY_RUN=true
